{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "Order System — Events",
  "tags": ["ordersys"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Events published /s (by type)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(events_published_total[1m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Events consumed /s (by outcome)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(events_consumed_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Handler p95 processing time (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, type) (rate(event_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dead-lettered messages (total)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "sum(events_consumed_total{status=\"dlq\"})" }]
    }
  ]
}
