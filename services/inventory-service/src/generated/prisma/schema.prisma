generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("INVENTORY_DATABASE_URL")
}

enum ReservationStatus {
  HELD
  COMMITTED
  RELEASED
}

model Product {
  id        String     @id @default(uuid())
  sku       String     @unique
  name      String
  price     Decimal    @db.Decimal(12, 2)
  inventory Inventory?

  @@map("products")
}

model Inventory {
  productId String  @id
  available Int
  reserved  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model Reservation {
  id        String            @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  status    ReservationStatus @default(HELD)
  createdAt DateTime          @default(now())

  @@index([orderId])
  @@map("reservations")
}

/// Idempotency ledger — see the same model in the order service.
model ProcessedMessage {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@map("processed_messages")
}
