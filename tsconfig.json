{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ordersys/shared": ["packages/shared/src/index.ts"],
      "@ordersys/shared/*": ["packages/shared/src/*"]
    },
    "noEmit": true
  },
  "include": ["packages/**/*.ts", "services/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "**/dist", "**/generated", "**/*.test.ts", "tests"]
}
